{
  "name": "subtitle-studio",
  "version": "1.0.2",
  "private": true,
  "description": "Desktop GUI for subtitle.py",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && node scripts/start-electron.cjs\"",
    "build": "npm run build:electron && vite build",
    "build:python": ".venv/bin/python -m PyInstaller --clean --onefile --name subtitle-cli --paths . scripts/subtitle_cli_entry.py",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:app": "npm run build && npm run build:python && electron-builder --mac dir",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "local.subtitle-studio",
    "productName": "Subtitle Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "public/icon.png"
    ],
    "extraResources": [
      {
        "from": "dist/subtitle-cli",
        "to": "bin/subtitle-cli"
      }
    ],
    "mac": {
      "icon": "public/icon.png",
      "target": [
        "dir"
      ],
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^37.0.0",
    "electron-builder": "^26.15.3",
    "lucide-react": "^0.468.0",
    "postcss": "^8.5.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0"
  }
}
